---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { getCollection } from "astro:content";
import SchemaInjector from "../components/seo/SchemaInjector.astro";

interface Props {
  title: string;
  slug: string;
  description: string;
  keyword: string;
  category: string;
  cluster: string;
  tags: string[];
  date: string;
  headings: { depth: number; slug: string; text: string }[];
  
  // Nuevos metadatos de validación y esquema
  fechaVerificacion: Date;
  tipoEsquema: 'faq' | 'howto' | 'article';
  preguntasFrecuentes?: Array<{ pregunta: string; respuesta: string }>;
  author?: string;
  reviewedBy?: string;
}

const {
  title,
  slug,
  description,
  keyword,
  category,
  cluster,
  tags,
  date,
  headings,
  fechaVerificacion,
  tipoEsquema,
  preguntasFrecuentes,
  author,
  reviewedBy
} = Astro.props;

const canonicalURL = `https://chequearapp.com.ar/blog/${slug}`;

// --- Interlinking logic ---
const allPosts = await getCollection("blog");
const currentSlug = slug;

// 1 pilar del mismo clúster
const clusterPilar = allPosts.find(
  (p) =>
    p.data.slug !== currentSlug &&
    p.data.cluster === cluster &&
    p.data.category === "pilar"
);

// 2 artículos relacionados (mismo clúster, distinto del pilar encontrado)
const relatedArticles = allPosts
  .filter(
    (p) =>
      p.data.slug !== currentSlug &&
      p.data.slug !== clusterPilar?.data.slug &&
      (p.data.cluster === cluster ||
        p.data.tags?.some((t: string) => tags?.includes(t)))
  )
  .slice(0, 3);

// Guía principal
const mainGuide = allPosts.find(
  (p) => p.data.slug === "guia-cheques-argentina"
);

const relatedLinks = [
  ...(clusterPilar ? [clusterPilar] : []),
  ...relatedArticles,
  ...(mainGuide && mainGuide.data.slug !== currentSlug ? [mainGuide] : []),
];

// --- TOC from headings ---
const tocItems = headings.filter((h) => h.depth <= 3);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: "https://chequearapp.com.ar",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: "https://chequearapp.com.ar/blog",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: title,
      item: canonicalURL,
    },
  ],
};

const categoryLabel =
  category === "pilar"
    ? "Guía Completa"
    : category === "educativo"
      ? "Artículo Educativo"
      : "Consulta Práctica";

const categoryColor =
  category === "pilar"
    ? "bg-accent/15 text-accent border-accent/20"
    : category === "educativo"
      ? "bg-blue-500/15 text-blue-400 border-blue-500/20"
      : "bg-amber-500/15 text-amber-400 border-amber-500/20";

// Reading time estimate
const wordsPerMinute = 200;
const articleText = title + " " + description;
const wordCount = articleText.split(/\s+/).length + (tocItems.length * 80); // rough estimate
const readingTime = Math.max(3, Math.ceil(wordCount / wordsPerMinute));

// Frontmatter risk data
const post = allPosts.find(p => p.data.slug === currentSlug);
const nivelRiesgo = (post?.data as any)?.nivelRiesgo;
const normativaAplicable = (post?.data as any)?.normativaAplicable;
const multaEstimada = (post?.data as any)?.multaEstimada;

const riesgoStyles: Record<string, {label:string, color:string, bg:string, dot:string}> = {
  bajo: { label: 'Bajo', color: 'text-emerald-400', bg: 'bg-emerald-500/10', dot: 'bg-emerald-500' },
  medio: { label: 'Moderado', color: 'text-amber-400', bg: 'bg-amber-500/10', dot: 'bg-amber-500' },
  alto: { label: 'Crítico', color: 'text-rose-400', bg: 'bg-rose-500/10', dot: 'bg-rose-500' },
};
const riesgoStyle = nivelRiesgo ? riesgoStyles[nivelRiesgo] : null;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | ChequeAR</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keyword} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | ChequeAR`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="es_AR" />

    <!-- Schema Markup -->
    <SchemaInjector 
      title={title}
      description={description}
      tipoEsquema={tipoEsquema}
      fechaVerificacion={fechaVerificacion}
      preguntasFrecuentes={preguntasFrecuentes}
      author={author}
      reviewedBy={reviewedBy}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema)}
    />

    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
    <!-- Google Fonts - Sora -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body
    class="antialiased selection:bg-accent selection:text-white overflow-x-hidden bg-primary text-primary-foreground"
  >
    <!-- Reading progress bar -->
    <div id="reading-progress" class="fixed top-0 left-0 h-[3px] bg-gradient-to-r from-accent via-accent/80 to-emerald-400 z-[100] origin-left" style="transform: scaleX(0); transition: transform 0.15s ease-out;"></div>

    <!-- Background gradient -->
    <div
      class="fixed inset-0 pointer-events-none -z-50 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-accent/10 via-primary to-primary"
    >
    </div>

    <Header />

    <main class="relative z-10 w-full flex flex-col items-center overflow-hidden">
      <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-16">
        
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-white/30 mb-10 font-medium" aria-label="Breadcrumb">
          <a href="/" class="hover:text-accent transition-colors duration-300 flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
            Inicio
          </a>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-white/15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          <a href="/blog" class="hover:text-accent transition-colors duration-300">Blog</a>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-white/15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          <span class="text-white/50 truncate max-w-[220px]">{title}</span>
        </nav>

        <!-- ====== Article Header (Full-width) ====== -->
        <!-- ====== Article Header (Centered) ====== -->
        <header class="mb-12 max-w-3xl mx-auto text-center flex flex-col items-center" data-aos="fade-up">
          <!-- Category Badge + Date + Reading Time -->
          <div class="flex flex-wrap items-center justify-center gap-3 mb-6">
            <span class={`inline-flex items-center px-3 py-1 rounded-full text-[11px] font-semibold border tracking-wide ${categoryColor}`}>
              {categoryLabel}
            </span>
            <span class="text-white/15">·</span>
            <time class="text-sm text-white/35 font-medium" datetime={date}>
              {new Date(date).toLocaleDateString("es-AR", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
            <span class="text-white/15">·</span>
            <span class="text-sm text-white/35 font-medium flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              {readingTime} min de lectura
            </span>
          </div>

          <!-- H1 -->
          <h1 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-extrabold text-white leading-[1.15] tracking-tight">
            {title}
          </h1>

          <!-- Description -->
          <p class="mt-5 text-lg text-white/50 leading-relaxed max-w-2xl font-light mx-auto">
            {description}
          </p>
        </header>

        <!-- ====== Single-column Article ====== -->
        <div class="max-w-4xl mx-auto">

          <!-- ====== Article Content ====== -->
          <article id="article-content">

            <!-- Article Content -->
            <div class="prose prose-invert prose-lg max-w-none
              [&>h2]:text-2xl md:[&>h2]:text-[1.7rem] [&>h2]:font-bold [&>h2]:text-white [&>h2]:mt-14 [&>h2]:mb-6 [&>h2]:pb-3 [&>h2]:border-b [&>h2]:border-white/[0.06] [&>h2]:leading-tight
              [&>h3]:text-xl md:[&>h3]:text-[1.35rem] [&>h3]:font-semibold [&>h3]:text-white/90 [&>h3]:mt-10 [&>h3]:mb-5
              [&>p]:text-white/65 [&>p]:leading-[1.85] [&>p]:mb-6 [&>p]:tracking-[0.01em]
              [&>ul]:text-white/65 [&>ul]:space-y-2.5 [&>ul]:mb-7 [&>ul]:ml-1 [&>ul>li]:marker:text-accent/60
              [&>ol]:text-white/65 [&>ol]:space-y-2.5 [&>ol]:mb-7 [&>ol]:ml-1 [&>ol>li]:marker:text-accent/60 [&>ol>li]:marker:font-semibold
              [&>li]:text-white/65 [&>li]:leading-relaxed
              [&>blockquote]:border-l-[3px] [&>blockquote]:border-accent/40 [&>blockquote]:bg-gradient-to-r [&>blockquote]:from-accent/[0.04] [&>blockquote]:to-transparent [&>blockquote]:rounded-r-xl [&>blockquote]:py-4 [&>blockquote]:px-6 [&>blockquote]:my-8 [&>blockquote]:italic [&>blockquote]:text-white/70
              [&>strong]:text-white [&>strong]:font-semibold
              [&>a]:text-accent [&>a]:font-medium [&>a]:underline [&>a]:underline-offset-4 [&>a]:decoration-accent/30 hover:[&>a]:decoration-accent [&>a]:transition-colors
              [&_strong]:text-white [&_strong]:font-semibold
              [&_a]:text-accent [&_a]:font-medium [&_a]:underline [&_a]:underline-offset-4 [&_a]:decoration-accent/30 hover:[&_a]:decoration-accent [&_a]:transition-colors
              [&>img]:rounded-2xl [&>img]:border [&>img]:border-white/[0.06] [&>img]:shadow-2xl [&>img]:my-10
              [&>pre]:rounded-xl [&>pre]:border [&>pre]:border-white/[0.06] [&>pre]:shadow-2xl [&>pre]:my-8 [&>pre]:p-5
              [&>code]:bg-white/[0.06] [&>code]:rounded-md [&>code]:px-1.5 [&>code]:py-0.5 [&>code]:text-accent/80 [&>code]:text-[0.9em]"
            >
              <slot />
            </div>

            <!-- ====== FAQ Accordion ====== -->
            {preguntasFrecuentes && preguntasFrecuentes.length > 0 && (
              <section class="mt-16 mb-10" id="faq-section">
                <div class="flex items-center gap-3 mb-8">
                  <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-accent">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  </div>
                  <h2 class="text-xl md:text-2xl font-bold text-white">
                    Preguntas Frecuentes
                  </h2>
                </div>

                <div class="space-y-3">
                  {preguntasFrecuentes.map((faq, index) => (
                    <div class="faq-item rounded-xl border border-white/[0.06] bg-white/[0.02] overflow-hidden transition-colors hover:border-white/[0.1]">
                      <button
                        class="faq-trigger w-full flex items-center justify-between text-left p-5 text-sm font-semibold text-white/80 hover:text-white transition-colors cursor-pointer"
                        data-faq-index={index}
                        aria-expanded="false"
                      >
                        <span class="pr-4">{faq.pregunta}</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="faq-chevron h-4 w-4 flex-shrink-0 text-white/30 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                      </button>
                      <div class="faq-answer" data-faq-answer={index}>
                        <div>
                          <div class="px-5 pb-5 pt-0">
                            <p class="text-sm text-white/50 leading-relaxed">{faq.respuesta}</p>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </section>
            )}



            <!-- ====== Share Section ====== -->
            <div class="mt-14 mb-2" data-aos="fade-up">
              <div class="rounded-2xl border border-white/[0.07] bg-white/[0.02] p-6 sm:p-8 flex flex-col sm:flex-row sm:items-center gap-6">
                <div class="flex-1 min-w-0">
                  <p class="text-[11px] font-semibold tracking-widest text-accent/60 uppercase mb-1">Compartir</p>
                  <p class="text-sm text-white/40 leading-relaxed">¿Te resultó útil? Compartilo con quien lo necesite.</p>
                </div>
                <div class="flex items-center gap-2 flex-wrap">
                  <!-- WhatsApp -->
                  <a
                    id="share-whatsapp"
                    href="#"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Compartir en WhatsApp"
                    class="share-btn group flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white/[0.04] border border-white/[0.08] hover:border-[#25D366]/40 hover:bg-[#25D366]/10 transition-all duration-300 text-white/50 hover:text-[#25D366]"
                  >
                    <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                    <span class="text-xs font-semibold">WhatsApp</span>
                  </a>
                  <!-- X / Twitter -->
                  <a
                    id="share-twitter"
                    href="#"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Compartir en X"
                    class="share-btn group flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white/[0.04] border border-white/[0.08] hover:border-white/25 hover:bg-white/[0.08] transition-all duration-300 text-white/50 hover:text-white"
                  >
                    <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.736-8.858L1.254 2.25H8.08l4.259 5.629L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
                    </svg>
                    <span class="text-xs font-semibold">X</span>
                  </a>
                  <!-- LinkedIn -->
                  <a
                    id="share-linkedin"
                    href="#"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Compartir en LinkedIn"
                    class="share-btn group flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white/[0.04] border border-white/[0.08] hover:border-[#0A66C2]/40 hover:bg-[#0A66C2]/10 transition-all duration-300 text-white/50 hover:text-[#0A66C2]"
                  >
                    <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                    <span class="text-xs font-semibold">LinkedIn</span>
                  </a>
                  <!-- Copy Link -->
                  <button
                    id="share-copy"
                    aria-label="Copiar enlace"
                    class="group flex items-center gap-2 px-4 py-2.5 rounded-xl bg-accent/10 border border-accent/20 hover:bg-accent/20 hover:border-accent/40 transition-all duration-300 text-accent/70 hover:text-accent cursor-pointer"
                  >
                    <svg id="share-copy-icon" class="h-4 w-4 flex-shrink-0 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                    </svg>
                    <span id="share-copy-label" class="text-xs font-semibold">Copiar link</span>
                  </button>
                </div>
              </div>
            </div>

            <!-- Related Articles -->
            {relatedLinks.length > 0 && (
              <div class="mt-16">
                <h2 class="text-lg font-bold text-white mb-6 flex items-center gap-2.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
                  Artículos relacionados
                </h2>
                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
                  {relatedLinks.map((post) => (
                    <a
                      href={`/blog/${post.data.slug}`}
                      class="group relative p-5 rounded-xl bg-white/[0.02] border border-white/[0.06] hover:border-accent/20 hover:bg-white/[0.04] transition-all duration-300"
                    >
                      <span class="text-sm font-semibold text-white/80 group-hover:text-accent transition-colors duration-300 block leading-snug">
                        {post.data.title}
                      </span>
                      <p class="text-xs text-white/30 mt-2.5 line-clamp-2 leading-relaxed">
                        {post.data.description}
                      </p>
                      <div class="mt-3 flex items-center gap-1.5 text-accent/50 group-hover:text-accent transition-colors">
                        <span class="text-[11px] font-medium">Leer más</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </article>
        </div>
      </div>
    </main>

    <Footer />

    <!-- AOS JS -->
    <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script is:inline>
      AOS.init({ duration: 800, once: true, offset: 50 });
    </script>

    <!-- Scroll-Spy, Reading Progress, FAQ & Mobile TOC -->
    <script is:inline>
      (function() {
        // === Reading Progress Bar ===
        const progressBar = document.getElementById('reading-progress');
        const articleContent = document.getElementById('article-content');

        function updateProgress() {
          if (!articleContent || !progressBar) return;
          const rect = articleContent.getBoundingClientRect();
          const articleTop = rect.top + window.scrollY;
          const articleHeight = rect.height;
          const viewportHeight = window.innerHeight;
          const scrolled = window.scrollY - articleTop + viewportHeight * 0.3;
          const progress = Math.max(0, Math.min(1, scrolled / articleHeight));
          progressBar.style.transform = `scaleX(${progress})`;
        }

        // === Scroll-Spy for Desktop TOC ===
        const tocLinks = document.querySelectorAll('[data-toc-slug]');
        const tocDots = document.querySelectorAll('[data-toc-dot]');
        const headingIds = Array.from(tocLinks).map(link => link.getAttribute('data-toc-slug'));

        function updateScrollSpy() {
          const scrollPosition = window.scrollY + 120;
          let activeId = null;

          for (let i = headingIds.length - 1; i >= 0; i--) {
            const el = document.getElementById(headingIds[i]);
            if (el && el.offsetTop <= scrollPosition) {
              activeId = headingIds[i];
              break;
            }
          }

          tocLinks.forEach(link => {
            const slug = link.getAttribute('data-toc-slug');
            if (slug === activeId) {
              link.classList.add('is-active');
            } else {
              link.classList.remove('is-active');
            }
          });

          tocDots.forEach(dot => {
            const slug = dot.getAttribute('data-toc-dot');
            if (slug === activeId) {
              dot.classList.add('is-active');
            } else {
              dot.classList.remove('is-active');
            }
          });
        }

        // Combined scroll handler with throttle
        let ticking = false;
        window.addEventListener('scroll', function() {
          if (!ticking) {
            window.requestAnimationFrame(function() {
              updateProgress();
              updateScrollSpy();
              ticking = false;
            });
            ticking = true;
          }
        });

        updateProgress();
        updateScrollSpy();

        // === FAQ Accordion ===
        const faqTriggers = document.querySelectorAll('.faq-trigger');
        faqTriggers.forEach(trigger => {
          trigger.addEventListener('click', function() {
            const index = this.getAttribute('data-faq-index');
            const answer = document.querySelector(`[data-faq-answer="${index}"]`);
            const chevron = this.querySelector('.faq-chevron');
            const isOpen = answer.classList.contains('is-open');

            // Close all others
            document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('is-open'));
            document.querySelectorAll('.faq-chevron').forEach(c => c.style.transform = '');
            document.querySelectorAll('.faq-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));

            if (!isOpen) {
              answer.classList.add('is-open');
              chevron.style.transform = 'rotate(180deg)';
              this.setAttribute('aria-expanded', 'true');
            }
          });
        });

        // === Mobile TOC Toggle ===
        const mobileTocToggle = document.getElementById('mobile-toc-toggle');
        const mobileTocContent = document.getElementById('mobile-toc-content');
        const mobileTocChevron = document.getElementById('mobile-toc-chevron');

        if (mobileTocToggle && mobileTocContent) {
          mobileTocToggle.addEventListener('click', function() {
            const isOpen = mobileTocContent.classList.contains('is-open');
            if (isOpen) {
              mobileTocContent.classList.remove('is-open');
              mobileTocChevron.style.transform = '';
            } else {
              mobileTocContent.classList.add('is-open');
              mobileTocChevron.style.transform = 'rotate(180deg)';
            }
          });

          // Close mobile TOC when clicking a link
          document.querySelectorAll('.mobile-toc-link').forEach(link => {
            link.addEventListener('click', () => {
              mobileTocContent.classList.remove('is-open');
              mobileTocChevron.style.transform = '';
            });
          });
        }
      })();
    </script>

    <!-- Share Buttons Init -->
    <script is:inline>
      (function () {
        const url = encodeURIComponent(window.location.href);
        const title = encodeURIComponent(document.title);

        const wa = document.getElementById('share-whatsapp');
        const tw = document.getElementById('share-twitter');
        const li = document.getElementById('share-linkedin');
        const cp = document.getElementById('share-copy');
        const cpLabel = document.getElementById('share-copy-label');
        const cpIcon = document.getElementById('share-copy-icon');

        if (wa) wa.href = `https://wa.me/?text=${title}%20${url}`;
        if (tw) tw.href = `https://x.com/intent/tweet?text=${title}&url=${url}`;
        if (li) li.href = `https://www.linkedin.com/sharing/share-offsite/?url=${url}`;

        if (cp) {
          cp.addEventListener('click', function () {
            navigator.clipboard.writeText(window.location.href).then(function () {
              cpLabel.textContent = '¡Copiado!';
              cpIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />';
              cp.classList.add('border-accent/60', 'bg-accent/20', 'text-accent');
              setTimeout(function () {
                cpLabel.textContent = 'Copiar link';
                cpIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />';
                cp.classList.remove('border-accent/60', 'bg-accent/20', 'text-accent');
              }, 2500);
            });
          });
        }
      })();
    </script>

    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>
  </body>
