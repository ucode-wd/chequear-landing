---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "¿Querés verificar el riesgo de este cheque?", 
  description = "Con ChequeAR podés escanear o ingresar el CUIT del emisor y conocer su historial crediticio, deudas del BCRA y riesgo de rechazo al instante en tu celular."
} = Astro.props;
---

<div class="my-10 relative overflow-hidden rounded-2xl border border-accent/20 bg-gradient-to-br from-accent/[0.08] via-accent/[0.03] to-primary/[0.01] backdrop-blur-xl p-6 md:p-8 shadow-2xl group">
  <!-- Decorative glows -->
  <div class="absolute -right-20 -top-20 w-44 h-44 rounded-full bg-accent/10 blur-3xl pointer-events-none group-hover:bg-accent/15 transition-colors duration-700"></div>
  <div class="absolute -left-16 -bottom-16 w-36 h-36 rounded-full bg-accent/5 blur-2xl pointer-events-none"></div>

  <div class="relative flex flex-col md:flex-row items-center gap-6 justify-between">
    <div class="flex-1 text-center md:text-left">
      <h3 class="text-lg md:text-xl font-bold text-primary leading-tight font-[Sora,Inter,system-ui,sans-serif]">
        {title}
      </h3>
      <p class="mt-2.5 text-sm text-primary/50 leading-relaxed max-w-2xl">
        {description}
      </p>
    </div>
    <div class="flex-shrink-0">
      <a 
        href="/#download" 
        class="inline-flex items-center justify-center px-7 py-3.5 rounded-full bg-accent !text-primary !no-underline font-semibold text-sm shadow-[0_0_30px_-5px_var(--color-accent)] hover:shadow-[0_0_45px_-5px_var(--color-accent)] hover:bg-accent/90 transition-all duration-300 hover:-translate-y-0.5"
      >
        Analizar Cheque Gratis
        <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </div>
</div>
