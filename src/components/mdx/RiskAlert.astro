---
interface Props {
  nivel: 'bajo' | 'medio' | 'alto';
}

const { nivel } = Astro.props;

const styles = {
  bajo: {
    border: 'border-emerald-500/30',
    glow: 'from-emerald-500/10 via-emerald-400/5 to-transparent',
    iconBg: 'bg-emerald-500/15',
    iconColor: 'text-emerald-400',
    labelColor: 'text-emerald-400',
    textColor: 'text-emerald-300/80',
    label: 'Riesgo Bajo',
    accentLine: 'bg-emerald-500',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    desc: 'Operación generalmente segura. Se recomienda verificación de rutina.'
  },
  medio: {
    border: 'border-amber-500/30',
    glow: 'from-amber-500/10 via-amber-400/5 to-transparent',
    iconBg: 'bg-amber-500/15',
    iconColor: 'text-amber-400',
    labelColor: 'text-amber-400',
    textColor: 'text-amber-300/80',
    label: 'Riesgo Moderado',
    accentLine: 'bg-amber-500',
    icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
    desc: 'Atención requerida. Existen factores que exigen una revisión detallada.'
  },
  alto: {
    border: 'border-rose-500/30',
    glow: 'from-rose-500/12 via-rose-400/5 to-transparent',
    iconBg: 'bg-rose-500/15',
    iconColor: 'text-rose-400',
    labelColor: 'text-rose-400',
    textColor: 'text-rose-300/80',
    label: 'Riesgo Crítico',
    accentLine: 'bg-rose-500',
    icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
    desc: 'Alerta de seguridad financiera o legal. Alta probabilidad de rechazo bancario o perjuicio patrimonial.'
  }
};

const current = styles[nivel] || styles.bajo;
---

<div class={`my-8 relative overflow-hidden rounded-2xl border ${current.border} bg-gradient-to-br from-white/[0.04] to-white/[0.01] backdrop-blur-xl p-5 md:p-6 shadow-2xl`}>
  <!-- Glow background -->
  <div class={`absolute inset-0 bg-gradient-to-br ${current.glow} pointer-events-none`}></div>
  <!-- Accent side line -->
  <div class={`absolute left-0 top-4 bottom-4 w-[3px] rounded-full ${current.accentLine} opacity-60`}></div>

  <div class="relative flex items-start gap-4">
    <!-- Icon -->
    <div class={`flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-xl ${current.iconBg} ${current.iconColor} shadow-inner`}>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d={current.icon} />
      </svg>
    </div>

    <!-- Content -->
    <div class="flex-1 min-w-0">
      <div class={`inline-flex items-center gap-2 text-xs font-bold tracking-widest uppercase ${current.labelColor}`}>
        <span class={`w-1.5 h-1.5 rounded-full ${current.accentLine} animate-pulse`}></span>
        {current.label}
      </div>
      <p class={`mt-2 text-sm leading-relaxed ${current.textColor}`}>
        <slot>{current.desc}</slot>
      </p>
    </div>
  </div>
</div>
