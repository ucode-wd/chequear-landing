---
interface Props {
  fecha: Date | string;
  normativa?: string;
}

const { fecha: rawFecha, normativa } = Astro.props;

const fecha = typeof rawFecha === 'string' ? new Date(rawFecha) : rawFecha;

// Formatear fecha de forma amigable (ej: "20 de Mayo, 2026")
const formattedDate = fecha.toLocaleDateString('es-AR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC' // Para evitar problemas de zona horaria que cambien el día
});
---

<div class="flex flex-wrap items-center gap-3 mb-8 pb-5 border-b border-white/[0.06]">
  <!-- Verified badge -->
  <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-semibold tracking-wide">
    <span class="relative flex h-2 w-2">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-60"></span>
      <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
    </span>
    Información Verificada
  </div>

  <span class="text-white/15 text-xs">•</span>

  <!-- Date -->
  <span class="text-xs font-medium text-white/40">
    Última revisión: <time datetime={fecha.toISOString()} class="text-white/60">{formattedDate}</time>
  </span>

  {normativa && (
    <>
      <span class="text-white/15 text-xs">•</span>
      <span class="text-xs text-white/40">
        Normativa: <strong class="font-semibold text-white/60">{normativa}</strong>
      </span>
    </>
  )}
</div>
