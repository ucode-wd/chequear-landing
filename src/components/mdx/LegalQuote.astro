---
interface Props {
  normativa: string;
}

const { normativa } = Astro.props;
---

<div class="my-8 relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-white/[0.04] to-white/[0.01] backdrop-blur-xl shadow-2xl">
  <!-- Accent left bar -->
  <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-gradient-to-b from-accent via-accent/60 to-transparent"></div>

  <div class="p-5 md:p-6 pl-6 md:pl-8">
    <!-- Header -->
    <div class="flex items-center gap-2.5 mb-4">
      <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-accent/10 text-accent">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
      </div>
      <span class="text-[10px] font-bold tracking-[0.15em] uppercase text-accent/80">
        Marco Regulatorio Aplicable
      </span>
    </div>

    <!-- Quote body -->
    <blockquote class="text-sm leading-relaxed text-white/70 italic pl-1 border-0">
      <slot />
    </blockquote>

    <!-- Source footer -->
    <div class="mt-4 pt-3 border-t border-white/5 flex items-center justify-end">
      <span class="text-[11px] font-medium text-white/30">
        — Fuente oficial: <span class="text-white/50 underline decoration-white/10 underline-offset-2">{normativa}</span>
      </span>
    </div>
  </div>
</div>
