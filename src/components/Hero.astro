<section
  class="relative w-full py-20 sm:py-32 min-h-screen flex flex-col justify-center"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full z-10 relative">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Texto -->
      <div class="text-center lg:text-left pt-12 lg:pt-0">
        <h1
          class="text-balance mx-auto lg:mx-0 text-4xl font-semibold tracking-tight sm:text-6xl lg:text-6xl leading-[1.1]"
          data-aos="fade-right"
        >
          Verificá cheques y eCheqs en <span class="bg-gradient-to-r from-primary-vivid via-primary-vibrant to-accent-brand bg-clip-text text-transparent font-extrabold"
            >segundos</span
          >
        </h1>

        <p
          class="mt-6 max-w-xl mx-auto lg:mx-0 text-lg leading-relaxed text-primary/70 sm:text-xl font-light"
          data-aos="fade-right"
          data-aos-delay="100"
        >
          Analizá el <strong>riesgo de cheque</strong> al instante. Escaneá y consultá
          cheques rechazados en Argentina con información oficial del BCRA y ARCA.
        </p>

        <!-- CTAs -->
        <div
          class="mt-10 flex flex-col justify-center lg:justify-start gap-4 sm:flex-row flex-wrap"
          data-aos="fade-right"
          data-aos-delay="200"
        >
          <a
            href="https://play.google.com/store/apps/details?id=com.ucode.chequear&hl=es_AR&pli=1"
            class="flex h-12 items-center justify-center rounded-full bg-primary-vibrant px-8 text-base font-semibold text-white shadow-[0_4px_20px_-4px_rgba(25,44,95,0.45)] hover:shadow-[0_8px_30px_-4px_rgba(25,44,95,0.55)] hover:bg-primary-vibrant/90 transition-all duration-300 animate-shimmer"
            style="background-image: linear-gradient(110deg, #192C5F 40%, #2a4585 50%, #192C5F 60%);"
          >
            Descargar en Android
          </a>

          <!-- Secundario: Verde marca (outline) -->
          <a
            href="https://apps.apple.com/ar/app/chequear-verific%C3%A1-cheques/id6756928345?l=en-GB"
            class="flex h-12 items-center justify-center rounded-full border border-accent-brand/50 px-8 text-base font-medium text-accent hover:bg-accent-brand/8 hover:border-accent-brand/70 transition-all duration-300"
          >
            Descargar en iOS
          </a>

          <!-- Secundario: Verde marca (outline) -->
          <a
            href="https://app.chequearapp.com.ar"
            class="flex h-12 items-center justify-center rounded-full border border-accent-brand/50 px-8 text-base font-medium text-accent hover:bg-accent-brand/8 hover:border-accent-brand/70 transition-all duration-300"
          >
            Abrir en mi PC
          </a>
        </div>

        <!-- Features -->
        <div
          class="mt-16 flex flex-wrap justify-center lg:justify-start items-center gap-8 text-primary/60"
          data-aos="fade-up"
          data-aos-delay="300"
        >
          <div
            class="flex items-center gap-3 text-sm font-medium tracking-wide string"
          >
            <svg
              class="h-5 w-5 text-accent-brand"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              viewBox="0 0 24 24"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="m9 12 2 2 4-4"></path>
            </svg>
            DATOS OFICIALES BCRA
          </div>

          <div
            class="flex items-center gap-3 text-sm font-medium tracking-wide"
          >
            <svg
              class="h-5 w-5 text-accent-brand"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              viewBox="0 0 24 24"
            >
              <path
                d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
              ></path>
            </svg>
            CONEXIÓN CON ARCA
          </div>
        </div>
      </div>
      <!-- Imagen -->
      <div
        class="relative flex items-center justify-center mt-12 lg:mt-0"
        data-aos="fade-left"
        data-aos-duration="1000"
      >
        <div
          class="relative mx-auto w-full max-w-[180px] sm:max-w-[220px] lg:w-auto lg:max-w-none flex items-center justify-center lg:-translate-y-8"
        >
          <!-- Glow -->
          <div
            class="absolute -inset-6 lg:-inset-12 rounded-full bg-accent-glow/20 blur-[60px] lg:blur-[80px] pointer-events-none"
          >
          </div>

          <!-- Imagen de atrás (MUY expuesta) -->
          <img
            src="hero1.webp"
            alt="ChequeAR App Screenshot secundaria"
            class="absolute rounded-[1.5rem] lg:rounded-[2.5rem] shadow-2xl w-full lg:w-auto lg:h-[550px] object-contain
                            -rotate-12 -translate-x-10 lg:-translate-x-16 translate-y-4 lg:translate-y-8
                            opacity-60 hover:opacity-100 animate-float animation-delay-600 transition-opacity duration-500"
          />

          <!-- Imagen principal -->
          <img
            src="hero2.webp"
            alt="ChequeAR App Screenshot"
            class="relative rounded-[1.5rem] lg:rounded-[2.5rem] shadow-2xl w-full lg:w-auto lg:h-[550px] object-contain
                            animate-float rotate-6 hover:rotate-2 transition-transform duration-500 border border-primary/10"
          />
        </div>
      </div>
    </div>
  </div>
</section>
